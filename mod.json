	"id": "le10x.double_click_exit",
	"version": "1.4.0",
	"name": "Double Click",
	"developer": "le10x",
	"description": "Double click to exit, restart or toggle practice mode.",
	"repository": "https://github.com",
	"tags": ["utility", "interface", "gameplay"],
	"settings": {
		"enable-double-click": {
			"name": "Enable Double Click",
			"description": "Activate the double click protection.",
			"type": "bool",
