		},
		"plat-only": {
			"name": "Platformer Only",
			"description": "Only active during plat levels.",
			"type": "bool",
			"default": false
		},
		"show-notification": {
			"name": "Show Notification",
			"description": "Show a message on the first click.",
			"type": "bool",
			"default": true
		},
		"custom-text": {
			"name": "Text Notification",
			"description": "The text that appears when you click a button once.",
			"type": "string",
			"default": "double click"
		},
		"click-speed": {
			"name": "Click Speed (ms)",
			"description": "Max time between clicks.",
			"type": "int",
			"default": 500,
			"min": 0,
			"max": 1000,
			"control": { "slider": true }
		}
	}
