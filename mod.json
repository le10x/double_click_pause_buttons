{
	"geode": "5.6.1",
	"gd": {
		"win": "2.2081",
		"android": "2.2081",
		"mac": "2.2081",
		"ios": "2.2081"
	},
	"id": "le10x.double_click_exit",
	"version": "1.0.0",
	"name": "Double Click Exit",
	"developer": "le10x",
	"description": "Requires a double click to exit the pause menu.",
	"settings": {
		"enable-double-click": {
			"name": "Enable Double Click",
			"type": "bool",
			"default": true
		},
		"plat-only": {
			"name": "Platformer Only",
			"type": "bool",
			"default": false
		},
		"show-notification": {
			"name": "Show Notification",
			"type": "bool",
			"default": true
		},
		"custom-text": {
			"name": "Custom Message",
			"type": "string",
			"default": "Click again to exit"
		},
		"click-speed": {
			"name": "Click Speed (ms)",
			"type": "int",
			"default": 500,
			"min": 0,
			"max": 1000,
			"control": { "slider": true }
		}
	}
}
