{
	"geode": "5.6.1",
	"gd": {
		"win": "2.2081",
		"android": "2.2081"
	},
	"id": "le10x_double_click_exit",
	"version": "1.0.0",
	"name": "Double Click Exit",
	"developer": "le10x",
	"description": "Requires a double click to exit the pause menu.",
	"settings": {
		"enable-confirm": {
			"name": "Enable Confirmation",
			"description": "Show a message before exiting.",
			"type": "bool",
			"default": true
		},
		"custom-text": {
			"name": "Custom Message",
			"description": "The text to show on the first click.",
			"type": "string",
			"default": "Click again to exit"
		},
		"click-speed": {
			"name": "Click Speed (ms)",
			"description": "Max time between clicks (0-1000ms).",
			"type": "int",
			"default": 500,
			"min": 0,
			"max": 1000,
			"control": {
				"slider": true
			}
		}
	}
}
